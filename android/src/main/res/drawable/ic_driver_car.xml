<?xml version="1.0" encoding="utf-8"?>
<!--
  GPS navigation arrow — like Google Maps / Uber navigation mode.
  Simple filled chevron pointing UP. MapLibre rotates the whole
  icon with the bearing so it always points in the direction of travel.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="48"
    android:viewportHeight="48">

    <!-- Outer arrow shape — dark fill -->
    <path
        android:fillColor="#18181b"
        android:pathData="
          M24,2
          L46,44
          L24,34
          L2,44
          Z"/>

    <!-- Inner cutout — creates the hollow chevron effect like Uber -->
    <path
        android:fillColor="#ffffff"
        android:pathData="
          M24,8
          L41,41
          L24,32
          L7,41
          Z"/>

    <!-- Dark arrow body on top of the white cutout — forms the chevron ring -->
    <path
        android:fillColor="#18181b"
        android:pathData="
          M24,14
          L38,40
          L24,33
          L10,40
          Z"/>

</vector>